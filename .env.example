TRASTCMS_ADMIN_EMAIL=admin@trastcms.local
TRASTCMS_ADMIN_PASSWORD=ChangeMeNow-2026!
TRASTCMS_ADMIN_NAME=Administrador
TRASTCMS_DATA_DIR=./data
TRASTCMS_BASE_URL=http://localhost:8080
TRASTCMS_PLUGIN_MASTER_KEY=change-this-plugin-master-key-before-production
SESSION_COOKIE_SECURE=false

# PostgreSQL example
# SPRING_PROFILES_ACTIVE=postgresql
# DATABASE_URL=jdbc:postgresql://localhost:5432/trastcms
# DATABASE_USERNAME=trastcms
# DATABASE_PASSWORD=change-me

# MySQL example
# SPRING_PROFILES_ACTIVE=mysql
# DATABASE_URL=jdbc:mysql://localhost:3306/trastcms?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
# DATABASE_USERNAME=trastcms
# DATABASE_PASSWORD=change-me

# Model Context Protocol (MCP)
TRASTCMS_MCP_ENABLED=true
TRASTCMS_MCP_ENDPOINT=/mcp
# Use un secreto largo y distinto de la contraseña administrativa.
TRASTCMS_MCP_TOKEN=replace-with-a-random-token-of-at-least-32-characters
